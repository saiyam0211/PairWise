{
  "expo": {
    "name": "PairWise",
    "slug": "PairWise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.PairWise.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FAF7F2"
      },
      "package": "com.PairWise.app",
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "scheme": "pairwise",
    "experiments": {
      "typedRoutes": true
    }
  }
}
