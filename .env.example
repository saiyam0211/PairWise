EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key-here

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Enable Google Sheets API + Google Drive API in your Google Cloud project.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Supabase Edge Function secrets (Web client ID + secret only):
# supabase secrets set GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=...

# --- GOOGLE CLOUD SETUP (3 separate OAuth clients) ---
#
# 1) WEB client — Authorized redirect URIs (https/localhost ONLY, no custom schemes):
#      http://localhost:8081
#      http://localhost:19006
#    Authorized JavaScript origins:
#      http://localhost:8081
#    Do NOT add com.PairWise.app:/oauthredirect here — Google rejects non-https URIs.
#
# 2) ANDROID client — Type "Android" (NOT Web):
#      Package name: com.PairWise.app
#      SHA-1 fingerprint: from npm run android:sha1 (after npx expo run:android)
#    No redirect URI field on Android clients.
#
# 3) iOS client — Bundle ID: com.PairWise.app
#
# All three client IDs must be DIFFERENT values in .env above.
# Google Sign-In does NOT work in Expo Go on Android — use: npx expo run:android
